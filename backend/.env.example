# Server
PORT=4000
NODE_ENV=development

# MongoDB connection string
# Local:  mongodb://localhost:27017/cf_bot_feedback
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cf_bot_feedback
MONGODB_URI=mongodb://localhost:27017/cf_bot_feedback

# CORS - origin allowed to call this API (e.g. the frontend URL)
CORS_ORIGIN=*

# --- Admin seed script (npm run seed:admin) ---
# Optional fallback used by `npm run seed:admin` if username/password
# aren't passed as CLI args: npm run seed:admin -- <username> <password>
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
