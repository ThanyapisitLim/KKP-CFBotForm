# See https://github.com/github/gitignore/blob/main/Go.gitignore

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
/bin/
/dist/

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html
coverage.out

# Dependency directories
vendor/

# Go workspace files (local multi-module dev only)
go.work
go.work.sum

# Air / Reflex live-reload tmp output
tmp/
*.air.toml.bak

# Env files / secrets
.env
.env.*
!.env.example

# Logs
*.log

# IDE
.idea/
.vscode/

# OS
.DS_Store
